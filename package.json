{
  "name": "calence",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm --filter @calence/api build",
    "dev": "pnpm --filter @calence/api dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm --filter @calence/api test",
    "typecheck": "pnpm --filter @calence/api typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "prettier": "^3.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
